  "optimizations": {
    "universal": {
      "prefer_keyboard_over_mouse": true,
      "address_bar_shortcut": "ctrl+l",
      "new_tab_shortcut": "ctrl+t",
      "close_tab_shortcut": "ctrl+w",
      "reload_shortcut": "f5",
      "find_on_page": "ctrl+f",
      "prefer_direct_url": true,
      "screenshot_verify_after_action": true,
      "wait_after_navigation": 1.5,
      "wait_after_app_open": 2.0
    },
    "browser_universal": {
      "navigate_to_url_sequence": [
        "keypress: Ctrl+L",
        "keypress: Ctrl+A",
        "type: {url}",
        "keypress: Enter",
        "wait: 1.5"
      ],
      "search_sequence": [
        "keypress: Ctrl+L",
        "type: {query}",
        "keypress: Enter",
        "wait: 2.0"
      ],
      "open_new_tab_sequence": [
        "keypress: Ctrl+T",
        "type: {url_or_query}",
        "keypress: Enter"
      ]
    },
    "system_detection": {
