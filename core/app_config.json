{
  "version": "1.0",
  "spec_sources": [
    "agent_rules/browser_navigation_spec.md",
    "agent_rules/agent_navigation.md",
    "agent_rules/agent_universal_optimize.md"
  ],
  "default_browser": "chrome",
  "never_default_to": ["arc"],
  "browser_task_keywords": [
    "search", "navigate", "go to", "visit", "browse", "open website",
    "youtube", "google", "github", "gmail", "web", "website", "url",
    "look up", "find online", "news", "article", "paper", "page"
  ],
  "browsers": {
    "chrome": {
      "keywords": [
        "chrome", "google chrome", "chromium"
      ],
      "process": "chrome.exe",
      "path": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
      "window_class": "Chrome_WidgetWin_1",
      "window_title_contains": ["Google Chrome", "Chrome"],
      "is_default": true,
      "search_url": "https://www.google.com/search?q={query}",
      "navigation": {
        "focus_address_bar": "ctrl+l",
        "new_tab": "ctrl+t",
        "close_tab": "ctrl+w",
        "reload": "f5",
        "hard_reload": "ctrl+shift+r",
        "settings_url": "chrome://settings",
        "action_sequence_navigate": [
          "keypress: Ctrl+L",
          "keypress: Ctrl+A",
          "type: {url}",
          "keypress: Enter",
          "wait: 1.5"
        ],
        "action_sequence_search": [
          "keypress: Ctrl+L",
          "type: {query}",
          "keypress: Enter",
          "wait: 2.0"
        ],
        "ui_descriptions": {
          "address_bar": "the address bar at the top of the Chrome browser",
          "menu": "the three dot menu at the very top right corner of Chrome",
          "new_tab": "the new tab button, a plus sign at the right end of the tab bar"
        }
      },
      "optimizations": [
        "prefer_ctrl_l_over_clicking_address_bar",
        "use_direct_url_navigation",
        "use_ctrl_t_for_new_tab"
      ]
    },
    "firefox": {
      "keywords": [
        "firefox", "mozilla firefox", "mozilla", "ff", "gecko"
      ],
      "process": "firefox.exe",
      "path": "C:\\Program Files\\Mozilla Firefox\\firefox.exe",
      "window_class": "MozillaWindowClass",
      "window_title_contains": ["Mozilla Firefox", "Firefox"],
      "is_default": false,
      "search_url": "https://www.google.com/search?q={query}",
      "navigation": {
        "focus_address_bar": "ctrl+l",
        "new_tab": "ctrl+t",
        "close_tab": "ctrl+w",
        "new_private_window": "ctrl+shift+p",
        "reload": "f5",
        "hard_reload": "ctrl+shift+r",
        "settings_url": "about:preferences",
        "action_sequence_navigate": [
          "keypress: Ctrl+L",
          "keypress: Ctrl+A",
          "type: {url}",
          "keypress: Enter",
          "wait: 1.5"
        ],
        "action_sequence_search": [
          "keypress: Ctrl+L",
          "type: {query}",
          "keypress: Enter",
          "wait: 2.0"
        ],
        "ui_descriptions": {
          "address_bar": "the address bar at the top of Firefox",
          "menu": "the hamburger menu, three horizontal lines at the top right of Firefox",
          "reader_view": "the Firefox reader view icon in the address bar"
        }
      },
      "optimizations": [
        "prefer_ctrl_l_over_clicking_address_bar",
        "use_direct_url_navigation"
      ]
    },
    "edge": {
      "keywords": [
        "edge", "microsoft edge", "msedge", "ms edge"
      ],
      "process": "msedge.exe",
      "path": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe",
      "window_class": "Chrome_WidgetWin_1",
      "window_title_contains": ["Microsoft Edge", "Edge"],
      "is_default": false,
      "search_url": "https://www.google.com/search?q={query}",
      "navigation": {
        "focus_address_bar": "ctrl+l",
        "new_tab": "ctrl+t",
        "close_tab": "ctrl+w",
        "immersive_reader": "f9",
        "copilot": "ctrl+shift+.",
        "reload": "f5",
        "settings_url": "edge://settings",
        "action_sequence_navigate": [
          "keypress: Ctrl+L",
          "keypress: Ctrl+A",
          "type: {url}",
          "keypress: Enter",
          "wait: 1.5"
        ],
        "action_sequence_search": [
          "keypress: Ctrl+L",
          "type: {query}",
          "keypress: Enter",
          "wait: 2.0"
        ],
