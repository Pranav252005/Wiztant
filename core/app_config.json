    "registry": {
      "keywords": [
        "registry", "regedit", "registry editor", "reg key", "reg edit",
        "hkey", "hkcu", "hklm", "hkey_current_user", "hkey_local_machine",
        "registry key", "registry value", "dword", "string value", "reg"
      ],
      "process": "regedit.exe",
      "path": "regedit.exe",
      "window_class": "RegEdit_MainFrame",
      "window_title_contains": ["Registry Editor"],
      "navigation": {
        "action_sequence_open": [
          "keypress: Win+R",
          "type: regedit",
          "keypress: Enter",
          "wait: 1.0",
          "click: Yes if UAC prompt appears"
        ],
        "action_sequence_navigate_to_key": [
          "click: the address bar at the top of Registry Editor",
          "type: {registry_path}",
          "keypress: Enter"
        ],
        "common_paths": {
          "startup_programs": "HKEY_CURRENT_USER\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",
          "uninstall": "HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall",
          "services": "HKEY_LOCAL_MACHINE\\SYSTEM\\CurrentControlSet\\Services",
          "current_user": "HKEY_CURRENT_USER",
          "local_machine": "HKEY_LOCAL_MACHINE"
        },
        "ui_descriptions": {
          "address_bar": "the address bar at the top of Registry Editor showing the current path",
          "tree": "the left panel tree view showing registry keys",
          "values": "the right panel showing registry values and data"
        }
      }
    },
