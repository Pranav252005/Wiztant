  "system_apps": {
    "settings": {
      "keywords": [
        "settings", "setting", "theme", "dark mode", "light mode", "night mode",
        "display", "sound", "audio", "volume", "network", "wifi", "bluetooth",
        "update", "windows update", "personalization", "wallpaper", "background",
        "privacy", "security", "account", "accounts", "language", "region",
        "accessibility", "power", "battery", "sleep", "hibernate",
        "notifications", "apps", "default apps", "startup apps",
        "color scheme", "accent color", "taskbar", "start menu"
