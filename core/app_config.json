      "process": "SystemSettings.exe",
      "path": "ms-settings:",
      "window_class": "Windows.UI.Core.CoreWindow",
      "window_title_contains": ["Settings"],
      "navigation": {
        "open_command": "ms-settings:",
        "action_sequence_open": [
          "keypress: Win",
          "type: Settings",
          "keypress: Enter",
          "wait: 1.5"
